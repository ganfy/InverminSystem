# =============================================================
#  INVERMIN PAITITI — Agente Balanza · Configuración
#  Ajustar según el modelo de balanza instalado en planta.
# =============================================================

# ── Puerto serial ──────────────────────────────────────────
BALANZA_COM_PORT=COM3
BALANZA_BAUD_RATE=9600
BALANZA_BYTE_SIZE=8
BALANZA_PARITY=N
BALANZA_STOP_BITS=1

# ── Interpretación del peso ────────────────────────────────
# Cuántos decimales tiene el valor crudo de la balanza.
# Ejemplos:
#   DECIMAL_PLACES=3 → "0012500" = 12.500 KG
#   DECIMAL_PLACES=2 → "0012500" = 125.00 KG
#   DECIMAL_PLACES=0 → "0012500" = 12500 KG (entero)
BALANZA_DECIMAL_PLACES=1

# Umbral de variación (KG) para considerar lectura estable
# 0.005 = el peso no varía más de 5 gramos entre tramas
BALANZA_STABILITY_THRESHOLD=0.005

# ── WebSocket local ────────────────────────────────────────
# El frontend Vue se conecta a esta dirección
BALANZA_WS_HOST=localhost
BALANZA_WS_PORT=8765

# ── Reconexión ─────────────────────────────────────────────
# Segundos entre reintentos si se pierde el puerto serial
BALANZA_RECONNECT_SEC=3
